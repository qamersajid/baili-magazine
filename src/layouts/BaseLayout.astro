---
const { title = 'Maheena War "Baili"', description = 'Haryanvi monthly web magazine' } = Astro.props;
---
<!doctype html>
<html lang="en" data-script="roman">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <style>
    @import url('https://fonts.googleapis.com/css2?family=Noto+Nastaliq+Urdu&family=Noto+Sans+Devanagari&family=Libre+Baskerville:wght@400;700&display=swap');

html[data-script="roman"] body{
  font-family: "Libre Baskerville", serif;
  direction: ltr;
}

html[data-script="urdu"] body{
  font-family: "Noto Nastaliq Urdu", serif;
  direction: rtl;
  font-size: 1.2rem;
  line-height: 2;
}

html[data-script="devanagari"] body{
  font-family: "Noto Sans Devanagari", sans-serif;
  direction: ltr;
}
    :root {
  --font-roman: 'Lora', serif;
  --font-urdu: 'Noto Nastaliq Urdu', serif;
  --font-devanagari: 'Noto Serif Devanagari', serif;
}

html[data-script="roman"] body {
  font-family: var(--font-roman);
  direction: ltr;
  text-align: left;
  line-height: 1.7;
}

html[data-script="urdu"] body {
  font-family: var(--font-urdu);
  direction: rtl;
  text-align: right;
  line-height: 2.2;
}

html[data-script="devanagari"] body {
  font-family: var(--font-devanagari);
  direction: ltr;
  text-align: left;
  line-height: 1.9;
}

.script-switcher {
  display: flex;
  gap: 0.5rem;
  align-items: center;
  flex-wrap: wrap;
}

.script-switcher button {
  border: 1px solid var(--line);
  background: var(--paper);
  color: var(--ink);
  padding: 0.35rem 0.8rem;
  border-radius: 999px;
  cursor: pointer;
  font: inherit;
}

.script-switcher button.active {
  background: var(--accent);
  color: white;
  border-color: var(--accent);
}
      :root {
        --bg: #f7f2e7;
        --paper: #fffaf1;
        --ink: #2e241b;
        --muted: #6f5b48;
        --accent: #7b4f2f;
        --line: #d9cbb8;
      }
      * { box-sizing: border-box; }
      body {
        margin: 0;
        font-family: Georgia, 'Noto Serif Devanagari', serif;
        background: var(--bg);
        color: var(--ink);
      }
      a { color: var(--accent); text-decoration: none; }
      a:hover { text-decoration: underline; }
      .container { width: min(1100px, 92vw); margin: 0 auto; }
      header {
        border-bottom: 1px solid var(--line);
        background: rgba(255,250,241,.9);
        position: sticky;
        top: 0;
        backdrop-filter: blur(8px);
      }
      nav {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        padding: 1rem 0;
      }
      .brand { font-size: 1.35rem; font-weight: 700; }
      .nav-links { display: flex; flex-wrap: wrap; gap: 1rem; }
      main { padding: 2rem 0 4rem; }
      .hero, .card, .issue-card, .author-card {
        background: var(--paper);
        border: 1px solid var(--line);
        border-radius: 18px;
        padding: 1.2rem;
        box-shadow: 0 6px 20px rgba(76, 51, 26, 0.06);
      }
      .hero { padding: 2rem; }
      .grid { display: grid; gap: 1rem; }
      .grid-3 { grid-template-columns: repeat(auto-fit, minmax(240px, 1fr)); }
      .grid-2 { grid-template-columns: repeat(auto-fit, minmax(300px, 1fr)); }
      h1, h2, h3 { margin-top: 0; }
      .muted { color: var(--muted); }
      .pill {
        display: inline-block;
        padding: .2rem .6rem;
        border: 1px solid var(--line);
        border-radius: 999px;
        font-size: .85rem;
        margin-right: .4rem;
      }
      footer { border-top: 1px solid var(--line); padding: 2rem 0 3rem; color: var(--muted); }
      .section-title { display: flex; justify-content: space-between; align-items: baseline; gap: 1rem; }
      .content p { line-height: 1.7; }
      .cover {
        width: 100%;
        aspect-ratio: 4/5;
        object-fit: cover;
        border-radius: 14px;
        border: 1px solid var(--line);
      }
      .button {
        display: inline-block;
        background: var(--accent);
        color: white;
        padding: .8rem 1rem;
        border-radius: 10px;
      }
    </style>
  </head>
  <body>
    <header>
      <div class="container">
        <nav>
          <a class="brand" href="/">Maheena War "Baili"</a>
          <div class="nav-links">
            <a href="/daily">Daily Contributions</a>
            <a href="/archive">Monthly Archive</a>
            <a href="/authors">Creators</a>
            <a href="/submit">Submit</a>
          </div>
          <div class="script-switcher">
            <button type="button" data-script-btn="urdu">اردو</button>
            <button type="button" data-script-btn="devanagari">देवनागरी</button>
            <button type="button" data-script-btn="roman">Roman</button>
          </div>
        </nav>
      </div>
    </header>
    <main>
      <div class="container">
        <slot />
      </div>
    </main>
    <footer>
      <div class="container">
        Baili is a Haryanvi web magazine for original prose and poetry. Built for Cloudflare Pages + Decap CMS.
      </div>
    </footer>
    <script is:inline>
const validScripts = ['roman','urdu','devanagari'];

function detectDefaultScript() {
  const saved = localStorage.getItem('baili-script');
  if(saved && validScripts.includes(saved)) return saved;

  const lang = (navigator.language || '').toLowerCase();

  if(lang.startsWith('ur')) return 'urdu';
  if(lang.startsWith('hi')) return 'devanagari';

  return 'roman';
}

function applyScript(script) {
  document.documentElement.setAttribute('data-script', script);
  localStorage.setItem('baili-script', script);

  document.querySelectorAll('[data-script-btn]').forEach(btn=>{
    btn.classList.toggle('active', btn.dataset.scriptBtn === script);
  });

  document.querySelectorAll('[data-roman][data-urdu][data-devanagari]').forEach(el=>{
    const value =
      script === 'urdu' ? el.dataset.urdu :
      script === 'devanagari' ? el.dataset.devanagari :
      el.dataset.roman;

    if(value) el.textContent = value;
  });
}

document.addEventListener('DOMContentLoaded',()=>{
  const selected = detectDefaultScript();
  applyScript(selected);

  document.querySelectorAll('[data-script-btn]').forEach(btn=>{
    btn.addEventListener('click',()=>applyScript(btn.dataset.scriptBtn));
  });
});
</script>
  </body>
</html>
