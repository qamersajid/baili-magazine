---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Submit | Baili">
  <section class="hero">
    <h1>Submit your original work</h1>
    <p>Replace the button below with your Google Form link. Ask for name, pen name, WhatsApp/email, category, title, original text, and originality declaration.</p>
    <p><a class="button" href="https://forms.google.com" target="_blank">Open submission form</a></p>
  </section>
</BaseLayout>
