---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection, getEntry } from 'astro:content';

export async function getStaticPaths() {
  const issues = await getCollection('issues');
  return issues.map((issue) => ({ params: { slug: issue.slug }, props: { issue } }));
}

const { issue } = Astro.props;
const allPosts = await getCollection('daily');
const selectedPosts = allPosts.filter(post => issue.data.featuredWritingSlugs.includes(post.slug));
const { Content } = await issue.render();
---
<BaseLayout title={`${issue.data.title} | Baili`}>
  <article class="hero">
    <h1>{issue.data.title}</h1>
    <p class="muted">{issue.data.month} {issue.data.year}</p>
    <p>{issue.data.editorialNote}</p>
    <div class="content"><Content /></div>
  </article>

  <section style="margin-top:2rem;">
    <h2>Contents</h2>
    <div class="grid grid-2">
      {selectedPosts.map(post => (
        <article class="card">
          <span class="pill">{post.data.genre}</span>
          <h3><a href={`/writings/${post.slug}`}>{post.data.title}</a></h3>
          <p class="muted">By {post.data.authorName}</p>
          <p>{post.data.summary}</p>
        </article>
      ))}
    </div>
  </section>
</BaseLayout>
